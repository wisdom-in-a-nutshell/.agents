{{!< default}}

{{!--
  Replace TURNSTILE_SITE_KEY with the real site key.
  Endpoint defaults to the AIP backend.
--}}

{{#page}}
  <section class="aip-contact">
    <h1 class="aip-contact-title">{{title}}</h1>
    <div class="aip-contact-content">
      {{content}}
    </div>

    <style>
      .aip-contact {
        padding: 2.5rem 1.5rem 4rem;
      }
      .aip-contact-title {
        text-align: center;
        font-size: clamp(2rem, 3vw, 3rem);
        margin-bottom: 1.5rem;
      }
      .aip-contact-content {
        max-width: 720px;
        margin: 0 auto 1.5rem;
      }
      .aip-contact-card {
        max-width: 760px;
        margin: 0 auto;
        padding: 2rem;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        background: #fff;
      }
      .aip-contact-form {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }
      .aip-contact-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.25rem;
      }
      .aip-contact-field label {
        display: block;
        font-weight: 600;
        margin-bottom: 0.4rem;
      }
      .aip-contact-field input,
      .aip-contact-field textarea {
        width: 100%;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        padding: 0.6rem 0.75rem;
        font: inherit;
        color: #111;
        background: #fff;
      }
      .aip-contact-field textarea {
        min-height: 180px;
        resize: vertical;
      }
      .aip-contact-center {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        text-align: center;
      }
      .aip-contact-button {
        background: var(--ghost-accent-color, #4a8f6a);
        color: #fff;
        border: 0;
        border-radius: 8px;
        padding: 0.6rem 1.25rem;
        font-weight: 600;
        cursor: pointer;
      }
      .aip-contact-button[disabled] {
        opacity: 0.6;
        cursor: not-allowed;
      }
      .aip-contact-status {
        font-size: 0.9rem;
      }
      .aip-contact-status--error {
        color: #b91c1c;
      }
      .aip-contact-status--success {
        color: #15803d;
      }
      @media (max-width: 640px) {
        .aip-contact-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>

    <div class="aip-contact-card">
      <form
        class="aip-contact-form"
        data-contact-form
        data-endpoint="https://aipodcasting-hzbxdueeg4eeatgh.eastus-01.azurewebsites.net/contact/form"
        data-turnstile-site-key="TURNSTILE_SITE_KEY"
      >
        <input type="hidden" name="timestamp" data-contact-timestamp>

        <div class="aip-contact-grid">
          <div class="aip-contact-field">
            <label for="contact-name">Name</label>
            <input id="contact-name" name="name" type="text" autocomplete="name" required>
          </div>
          <div class="aip-contact-field">
            <label for="contact-email">Email</label>
            <input id="contact-email" name="email" type="email" autocomplete="email" required>
          </div>
        </div>

        <div class="aip-contact-field">
          <label for="contact-message">Message</label>
          <textarea id="contact-message" name="message" rows="6" required></textarea>
        </div>

        <div class="aip-contact-center">
          <div class="cf-turnstile" data-sitekey="TURNSTILE_SITE_KEY" data-theme="light"></div>
        </div>

        <div class="hidden" aria-hidden="true">
          <label for="contact-website">Website</label>
          <input id="contact-website" name="website" type="text" autocomplete="off" tabindex="-1">
        </div>

        <div class="aip-contact-center">
          <button class="aip-contact-button" type="submit" data-contact-submit>
            Send
          </button>

          <p class="aip-contact-status aip-contact-status--error hidden" data-contact-status="config">
            Contact form is not configured yet.
          </p>
          <p class="aip-contact-status aip-contact-status--success hidden" data-contact-status="success">
            Thanks for the message. We will get back to you soon.
          </p>
          <p class="aip-contact-status aip-contact-status--error hidden" data-contact-status="error">
            Sorry, something went wrong. Please try again.
          </p>
        </div>
      </form>
    </div>
  </section>
{{/page}}

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

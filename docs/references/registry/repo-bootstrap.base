filters:
  and:
    - file.inFolder("docs/references/registry/repo-bootstrap-items")
properties:
  repo_name:
    displayName: Repo
  path:
    displayName: Path
  mcp_count:
    displayName: MCP Count
  mcps:
    displayName: MCPs
  skill_count:
    displayName: Skill Count
  repo_local_skill_count:
    displayName: Repo-Local Skill Count
  skills:
    displayName: Skills
  global_skills:
    displayName: Global Skills
  repo_skills:
    displayName: Repo Skills
  repo_local_skills:
    displayName: Repo-Local Skills
  model:
    displayName: Model
  reasoning:
    displayName: Reasoning
  fast_mode:
    displayName: Fast Mode
  service_tier:
    displayName: Service Tier
views:
  - type: table
    name: Repo Bootstrap
    order:
      - repo_name
      - mcps
      - skill_count
      - global_skills
      - repo_skills
      - repo_local_skills
      - model
      - reasoning
      - fast_mode
      - service_tier
  - type: table
    name: MCP Enabled
    filters: mcp_count > 0
    order:
      - repo_name
      - mcps
      - skill_count
      - global_skills
      - repo_skills
      - repo_local_skills
      - model
      - reasoning
      - fast_mode
      - service_tier
  - type: table
    name: Skills Enabled
    filters: skill_count > 0
    order:
      - repo_name
      - skill_count
      - global_skills
      - repo_skills
      - repo_local_skills
      - mcps
  - type: table
    name: Repo-Local Skills
    filters: repo_local_skill_count > 0
    order:
      - repo_name
      - repo_local_skills
      - repo_skills
      - global_skills
      - mcps
      - model
      - reasoning
      - fast_mode
      - service_tier

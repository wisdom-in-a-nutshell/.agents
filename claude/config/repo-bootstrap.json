{
  "defaults": {
    "link_claude_md_to_agents_md": true,
    "settings": {
      "$schema": "https://json.schemastore.org/claude-code-settings.json",
      "enableAllProjectMcpServers": true,
      "permissions": {
        "defaultMode": "bypassPermissions"
      },
      "sandbox": {
        "enabled": false
      }
    }
  },
  "mcp_presets": {
    "openaiDeveloperDocs": {
      "type": "http",
      "url": "https://developers.openai.com/mcp"
    },
    "paper": {
      "type": "http",
      "url": "http://127.0.0.1:29979/mcp"
    },
    "cloudflare-api": {
      "type": "http",
      "url": "https://mcp.cloudflare.com/mcp"
    },
    "cloudflare-docs": {
      "type": "http",
      "url": "https://docs.mcp.cloudflare.com/mcp"
    },
    "xcode": {
      "type": "stdio",
      "command": "xcrun",
      "args": [
        "mcpbridge"
      ]
    }
  },
  "repos": [
    {
      "path": "~/.agents",
      "mcp_presets": [
        "openaiDeveloperDocs"
      ]
    },
    {
      "path": "~/GitHub/.github"
    },
    {
      "path": "~/GitHub/adi",
      "mcp_presets": [
        "openaiDeveloperDocs",
        "paper"
      ]
    },
    {
      "path": "~/GitHub/adithyan-ai-videos"
    },
    {
      "path": "~/GitHub/aip-cognitive-revolution"
    },
    {
      "path": "~/GitHub/aipodcasting"
    },
    {
      "path": "~/GitHub/aipodcasting-public-website"
    },
    {
      "path": "~/GitHub/angie",
      "mcp_presets": [
        "openaiDeveloperDocs"
      ]
    },
    {
      "path": "~/GitHub/blog-personal",
      "mcp_presets": [
        "paper"
      ]
    },
    {
      "path": "~/GitHub/codexclaw",
      "mcp_presets": [
        "xcode",
        "openaiDeveloperDocs"
      ]
    },
    {
      "path": "~/GitHub/focus"
    },
    {
      "path": "~/GitHub/future-of-life-institute-podcast-aipodcast-ing-theme"
    },
    {
      "path": "~/GitHub/platform-ops",
      "mcp_presets": [
        "cloudflare-api",
        "cloudflare-docs"
      ]
    },
    {
      "path": "~/GitHub/litellm"
    },
    {
      "path": "~/GitHub/modal_functions"
    },
    {
      "path": "~/GitHub/scripts"
    },
    {
      "path": "~/GitHub/stadia-macos-controller"
    },
    {
      "path": "~/GitHub/thoughtforms-life-theme"
    },
    {
      "path": "~/GitHub/win",
      "mcp_presets": [
        "openaiDeveloperDocs"
      ]
    }
  ]
}

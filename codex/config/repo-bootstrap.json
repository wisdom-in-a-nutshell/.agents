{
  "defaults": {
    "model": "gpt-5.4",
    "model_reasoning_effort": "high",
    "service_tier": null
  },
  "mcp_presets": {
    "openaiDeveloperDocs": {
      "url": "https://developers.openai.com/mcp"
    },
    "xcode": {
      "command": "xcrun",
      "args": [
        "mcpbridge"
      ],
      "startup_timeout_sec": 180,
      "tool_timeout_sec": 120
    }
  },
  "repos": [
    {
      "path": "~/.agents",
      "mcp_presets": [
        "openaiDeveloperDocs"
      ]
    },
    {
      "path": "~/GitHub/.github"
    },
    {
      "path": "~/GitHub/adi",
      "model": "gpt-5.4",
      "model_reasoning_effort": "high",
      "model_verbosity": "low",
      "personality": "friendly",
      "service_tier": "fast",
      "model_instructions_file": "../soul.md",
      "project_root_markers": [],
      "mcp_presets": [
        "openaiDeveloperDocs"
      ]
    },
    {
      "path": "~/GitHub/adi-brand"
    },
    {
      "path": "~/GitHub/adithyan-ai-videos"
    },
    {
      "path": "~/GitHub/aip-cognitive-revolution"
    },
    {

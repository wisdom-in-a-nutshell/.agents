      "personality": "friendly",
      "service_tier": "fast",
      "model_instructions_file": "../soul.md",
      "project_root_markers": [],
      "mcp_presets": [
        "openaiDeveloperDocs"
      ]
    },
    {
      "path": "~/GitHub/audio-enhance"

{
  "defaults": {
    "model": "gpt-5.4",
    "model_reasoning_effort": "high",
    "features": {
      "fast_mode": true
    },
    "service_tier": null
  },
  "mcp_presets": {
    "openaiDeveloperDocs": {
      "url": "https://developers.openai.com/mcp"
    },
    "paper": {
      "url": "http://127.0.0.1:29979/mcp"
    },
    "cloudflare-api": {
      "url": "https://mcp.cloudflare.com/mcp"
    },
    "cloudflare-docs": {
      "url": "https://docs.mcp.cloudflare.com/mcp"
    },
    "xcode": {
      "command": "xcrun",
      "args": [
        "mcpbridge"
      ],
      "startup_timeout_sec": 180,
      "tool_timeout_sec": 120
    }
  },
  "repos": [
    {
      "path": "~/.agents",
      "mcp_presets": [
        "openaiDeveloperDocs"
      ]
    },
    {
      "path": "~/GitHub/.github"
    },
    {
      "path": "~/GitHub/adi",
      "model": "gpt-5.4",
      "model_reasoning_effort": "high",
      "model_verbosity": "low",
      "personality": "pragmatic",
      "service_tier": "fast",
      "model_instructions_file": "../soul.md",
      "project_root_markers": [],
      "mcp_presets": [
        "openaiDeveloperDocs",
        "paper"
      ]
    },
    {
      "path": "~/GitHub/adithyan-ai-videos"
    },
    {
      "path": "~/GitHub/aip-cognitive-revolution"
    },
    {
      "path": "~/GitHub/aipodcasting"
    },
    {
      "path": "~/GitHub/aipodcasting-public-website"
    },
    {
      "path": "~/GitHub/angie",
      "model": "gpt-5.4",
      "model_reasoning_effort": "high",
      "model_verbosity": "low",
      "personality": "friendly",
      "service_tier": "fast",
      "model_instructions_file": "../soul.md",
      "project_root_markers": [],
      "mcp_presets": [
        "openaiDeveloperDocs"
      ]
    },
    {
      "path": "~/GitHub/blog-personal"
    },
    {
      "path": "~/GitHub/codexclaw",
      "mcp_presets": [
        "xcode",
        "openaiDeveloperDocs"
      ]
    },
    {
      "path": "~/GitHub/focus"
    },
    {
      "path": "~/GitHub/future-of-life-institute-podcast-aipodcast-ing-theme"
    },
    {
      "path": "~/GitHub/platform-ops",
      "mcp_presets": [
        "cloudflare-api",
        "cloudflare-docs"
      ]
    },
    {
      "path": "~/GitHub/grateful-journal"
    },
    {
      "path": "~/GitHub/litellm"
    },
    {
      "path": "~/GitHub/modal_functions"
    },
    {
      "path": "~/GitHub/podcast-website-setup"
    },
    {
      "path": "~/GitHub/scripts"
    },
    {
      "path": "~/GitHub/stadia-macos-controller"
    },
    {
      "path": "~/GitHub/thoughtforms-life-theme"
    },
    {
      "path": "~/GitHub/win",
      "mcp_presets": [
        "openaiDeveloperDocs"
      ]
    }
  ]
}
